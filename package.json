{
  "name": "lever-fetch",
  "version": "0.1.0",
  "description": "CLI API testing tool for lever services.",
  "author": "Lever UI Team",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lever-fetch": "dist/cli.js"
  },
